      </div>

      <!-- Controles -->
      <button class="carousel-3d-btn carousel-3d-prev" id="carouselPrev" aria-label="Slide anterior">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="carousel-3d-btn carousel-3d-next" id="carouselNext" aria-label="Próximo slide">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <!-- Dots -->
      <div class="carousel-3d-dots" id="carouselDots"></div>
    </div>

    <div class="text-center mt-10">
      <a
        href="https://www.instagram.com/mundo_da_moda_miguelopolis/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 border border-branco-parede/20 text-branco-parede/70 hover:text-dourado-script hover:border-dourado-script/30 transition-all duration-300 font-semibold uppercase text-sm tracking-wider"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        Mais looks no Instagram
      </a>
    </div>
  </div>
</section>

<style>
  .carousel-3d-wrapper {
    position: relative;
    width: 100%;
    height: 520px;
    perspective: 1200px;
    perspective-origin: 50% 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-3d-container {
    position: relative;
    width: 320px;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
    will-change: transform;
  }

  .carousel-3d-slide {
    position: absolute;
    top: 10px;
    left: 0;
    width: 100%;
    height: calc(100% - 20px);
    border-radius: 2px;
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transition: opacity 0.4s ease-out;
  }

  .carousel-3d-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-3d-slide::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(22,19,15,0.6) 0%, transparent 40%);
    opacity: 0;
    transition: opacity 0.4s ease-out;
  }

  .carousel-3d-slide.active::after {
    opacity: 0;
  }

  .carousel-3d-slide.dim::after {
    opacity: 1;
  }

  /* Botões de navegação */
  .carousel-3d-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(247,245,242,0.2);
    background: rgba(22,19,15,0.7);
    color: rgba(247,245,242,0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease-out;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .carousel-3d-btn:hover {
    background: rgba(201,162,75,0.2);
    border-color: rgba(201,162,75,0.5);
    color: #C9A24B;
  }

  .carousel-3d-prev {
    left: calc(50% - 200px);
  }

  .carousel-3d-next {
    right: calc(50% - 200px);
  }

  /* Dots */
  .carousel-3d-dots {
    position: absolute;
    bottom: -40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 20;
  }

  .carousel-3d-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid rgba(247,245,242,0.3);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease-out;
    padding: 0;
  }

  .carousel-3d-dot.active {
    background: #C9A24B;
    border-color: #C9A24B;
    transform: scale(1.3);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .carousel-3d-wrapper {
      height: 420px;
      perspective: 900px;
    }

    .carousel-3d-container {
      width: 260px;
    }

    .carousel-3d-prev {
      left: 8px;
    }

    .carousel-3d-next {
      right: 8px;
    }

    .carousel-3d-btn {
      width: 40px;
      height: 40px;
    }
  }

  @media (max-width: 480px) {
    .carousel-3d-wrapper {
      height: 380px;
      perspective: 800px;
    }

    .carousel-3d-container {
      width: 220px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-3d-container {
      transition: none !important;
    }

    .carousel-3d-slide {
      transition: none !important;
    }
  }
</style>

<script>
  const SLIDES = [
    { src: '/galeria/look-cowboy.jpg', alt: 'Look country — vestido brilhante com chapéu e botas' },
    { src: '/galeria/conjunto-azul-floral.jpg', alt: 'Conjunto blazer e saia — estampa floral azul' },
    { src: '/galeria/calca-infantil.jpg', alt: 'Calça moletom infantil — conforto e qualidade' },
    { src: '/1.jpg', alt: 'Modelo com look da Mundo da Moda' },
    { src: '/ig_2.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_3.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_5.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_6.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_8.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_10.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_11.jpg', alt: 'Look da loja Mundo da Moda' },
  ];

  class Carousel3D {
    constructor() {
      this.slides = SLIDES;
      this.currentIndex = 0;
      this.isTransitioning = false;
      this.touchStartX = 0;
      this.touchDeltaX = 0;

      this.track = document.getElementById('carouselTrack');
      this.dotsContainer = document.getElementById('carouselDots');
      this.prevBtn = document.getElementById('carouselPrev');
      this.nextBtn = document.getElementById('carouselNext');
      this.wrapper = document.getElementById('carousel3d');

      this.build();
      this.bindEvents();
      this.update();
    }

    build() {
      this.slides.forEach((slide, i) => {
        const div = document.createElement('div');
        div.className = 'carousel-3d-slide';
        div.innerHTML = `<img src="${slide.src}" alt="${slide.alt}" loading="${i < 3 ? 'eager' : 'lazy'}" />`;
        this.track.appendChild(div);

        const dot = document.createElement('button');
        dot.className = 'carousel-3d-dot';
        dot.setAttribute('aria-label', `Ir para slide ${i + 1}`);
        dot.addEventListener('click', () => this.goTo(i));
        this.dotsContainer.appendChild(dot);
      });

      this.slideEls = this.track.querySelectorAll('.carousel-3d-slide');
      this.dotEls = this.dotsContainer.querySelectorAll('.carousel-3d-dot');
    }

    bindEvents() {
      this.prevBtn.addEventListener('click', () => this.prev());
      this.nextBtn.addEventListener('click', () => this.next());

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') this.prev();
        if (e.key === 'ArrowRight') this.next();
      });

      this.wrapper.addEventListener('touchstart', (e) => {
        this.touchStartX = e.touches[0].clientX;
        this.touchDeltaX = 0;
      }, { passive: true });

      this.wrapper.addEventListener('touchmove', (e) => {
        this.touchDeltaX = e.touches[0].clientX - this.touchStartX;
      }, { passive: true });

      this.wrapper.addEventListener('touchend', () => {
        if (Math.abs(this.touchDeltaX) > 60) {
          if (this.touchDeltaX > 0) this.prev();
          else this.next();
        }
        this.touchDeltaX = 0;
      });
    }

    goTo(index) {
      if (this.isTransitioning || index === this.currentIndex) return;
      if (index < 0) index = this.slides.length - 1;
      if (index >= this.slides.length) index = 0;

      this.isTransitioning = true;
      this.currentIndex = index;
      this.update();

      setTimeout(() => {
        this.isTransitioning = false;
      }, 700);
    }

    prev() {
      this.goTo(this.currentIndex - 1);
    }

    next() {
      this.goTo(this.currentIndex + 1);
    }

    update() {
      const total = this.slides.length;
      const containerW = this.track.parentElement.clientWidth;
      const slideW = Math.min(320, containerW - 80);
      const gapAngle = 12; // degrees between slides
      const zOffset = 380; // depth

      this.slideEls.forEach((el, i) => {
        el.style.width = `${slideW}px`;

        const offset = i - this.currentIndex;
        let angle, tz, ox, oy;

        if (offset === 0) {
          angle = 0;
          tz = 0;
          ox = 0;
          oy = 1;
          el.classList.add('active');
          el.classList.remove('dim');
        } else {
          angle = offset * gapAngle;
          tz = -zOffset;
          ox = offset * -0.2;
          oy = 0.85;
          el.classList.remove('active');
          el.classList.add('dim');
        }

        el.style.transform = `rotateY(${angle}deg) translateZ(${tz}px) scale(${oy})`;
        el.style.opacity = offset === 0 ? '1' : '0.35';
        el.style.zIndex = offset === 0 ? '10' : '1';
      });

      this.dotEls.forEach((el, i) => {
        el.classList.toggle('active', i === this.currentIndex);
      });
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    new Carousel3D();
    window.addEventListener('resize', () => {
      const carousel = document.querySelector('.carousel-3d-wrapper');
      if (carousel && carousel._instance) {
        carousel._instance.update();
      }
    });
  });

  new Carousel3D();
  const wrapperEl = document.querySelector('.carousel-3d-wrapper');
  if (wrapperEl) wrapperEl._instance = wrapperEl;
</script>
