  <div class="max-w-7xl mx-auto px-4 sm:px-8">
    <div class="text-center mb-12 sm:mb-16">
      <div class="flex items-center justify-center gap-3 mb-3">
        <img
          src="/hero0.jpeg"
          alt=""
          class="w-10 h-10 rounded-full object-cover"
          aria-hidden="true"
          loading="lazy"
          width="40"
          height="40"
        />
        <span class="text-amarelo-calcada font-semibold tracking-widest uppercase text-sm">Galeria</span>
      </div>
      <h2 class="text-branco-parede text-3xl sm:text-4xl font-bold">
        Looks que <span class="text-dourado-script">inspiram</span>
