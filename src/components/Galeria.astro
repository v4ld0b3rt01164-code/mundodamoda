<style>
  .carousel-stage {
    position: relative;
    width: 100%;
    height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .carousel-track {
    position: relative;
    width: 300px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-card {
    position: absolute;
    width: 100%;
    height: 90%;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.6s ease;
    will-change: transform, opacity;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }

  .carousel-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Overlay para slides laterais */
  .carousel-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(22, 19, 15, 0.55);
    transition: opacity 0.6s ease;
    pointer-events: none;
  }

  .carousel-card.is-center::after {
    opacity: 0;
  }

  /* Setas */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(247,245,242,0.2);
    background: rgba(22,19,15,0.8);
    color: rgba(247,245,242,0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .carousel-arrow:hover {
    background: rgba(201,162,75,0.2);
    border-color: rgba(201,162,75,0.5);
    color: #C9A24B;
  }

  .carousel-arrow:active {
    transform: translateY(-50%) scale(0.95);
  }

  .carousel-arrow--prev {
    left: 16px;
  }

  .carousel-arrow--next {
    right: 16px;
  }

  /* Dots */
  .carousel-dots {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid rgba(247,245,242,0.3);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }

  .carousel-dot.is-active {
    background: #C9A24B;
    border-color: #C9A24B;
    transform: scale(1.4);
  }

  @media (min-width: 640px) {
    .carousel-stage {
      height: 560px;
    }

    .carousel-track {
      width: 360px;
    }

    .carousel-arrow {
      width: 48px;
      height: 48px;
    }

    .carousel-arrow--prev {
      left: 24px;
    }

    .carousel-arrow--next {
      right: 24px;
    }
  }

  @media (min-width: 1024px) {
    .carousel-stage {
      height: 600px;
    }

    .carousel-track {
      width: 400px;
    }

    .carousel-arrow--prev {
      left: calc(50% - 280px);
    }

    .carousel-arrow--next {
      right: calc(50% - 280px);
    }
  }

  @media (max-width: 480px) {
    .carousel-stage {
      height: 400px;
    }

    .carousel-track {
      width: 260px;
    }

    .carousel-card {
      height: 88%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-card {
      transition: none !important;
    }
  }
</style>

<script>
  const SLIDES = [
    { src: '/galeria/look-cowboy.jpg', alt: 'Look country — vestido brilhante com chapéu e botas' },
    { src: '/galeria/conjunto-azul-floral.jpg', alt: 'Conjunto blazer e saia — estampa floral azul' },
    { src: '/galeria/calca-infantil.jpg', alt: 'Calça moletom infantil — conforto e qualidade' },
    { src: '/1.jpg', alt: 'Modelo com look da Mundo da Moda' },
    { src: '/ig_2.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_3.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_5.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_6.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_8.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_10.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_11.jpg', alt: 'Look da loja Mundo da Moda' },
  ];

  class Carousel3D {
    constructor() {
      this.slides = SLIDES;
      this.current = 0;
      this.animating = false;
      this.autoplay = null;
      this.touchX = 0;
      this.swipeX = 0;

      this.track = document.getElementById('carouselTrack');
      this.dotsEl = document.getElementById('carouselDots');
      this.prevBtn = document.getElementById('carouselPrev');
      this.nextBtn = document.getElementById('carouselNext');
      this.stage = document.getElementById('carouselStage');

      this.build();
      this.bind();
      this.render();
      this.startAutoplay();
    }

    build() {
      this.cards = this.slides.map((s, i) => {
        const el = document.createElement('div');
        el.className = 'carousel-card';
        el.innerHTML = `<img src="${s.src}" alt="${s.alt}" loading="${i < 2 ? 'eager' : 'lazy'}" />`;
        el.addEventListener('click', () => { if (i !== this.current) this.go(i); });
        this.track.appendChild(el);

        const dot = document.createElement('button');
        dot.className = 'carousel-dot';
        dot.setAttribute('aria-label', `Slide ${i + 1}`);
        dot.addEventListener('click', () => this.go(i));
        this.dotsEl.appendChild(dot);

        return { el, dot };
      });
    }

    bind() {
      this.prevBtn.addEventListener('click', () => { this.prev(); this.resetAutoplay(); });
      this.nextBtn.addEventListener('click', () => { this.next(); this.resetAutoplay(); });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') { this.prev(); this.resetAutoplay(); }
        if (e.key === 'ArrowRight') { this.next(); this.resetAutoplay(); }
      });

      this.stage.addEventListener('touchstart', (e) => {
        this.touchX = e.touches[0].clientX;
        this.swipeX = 0;
        this.pauseAutoplay();
      }, { passive: true });

      this.stage.addEventListener('touchmove', (e) => {
        this.swipeX = e.touches[0].clientX - this.touchX;
      }, { passive: true });

      this.stage.addEventListener('touchend', () => {
        if (Math.abs(this.swipeX) > 50) {
          this.swipeX > 0 ? this.prev() : this.next();
        }
        this.resetAutoplay();
      });

      this.stage.addEventListener('mouseenter', () => this.pauseAutoplay());
      this.stage.addEventListener('mouseleave', () => this.startAutoplay());
    }

    go(index) {
      if (this.animating || index === this.current) return;
      if (index < 0) index = this.slides.length - 1;
      if (index >= this.slides.length) index = 0;
      this.animating = true;
      this.current = index;
      this.render();
      setTimeout(() => { this.animating = false; }, 650);
    }

    prev() { this.go(this.current - 1); }
    next() { this.go(this.current + 1); }

    render() {
      const total = this.slides.length;
      const trackW = this.track.clientWidth;

      this.cards.forEach(({ el, dot }, i) => {
        let offset = i - this.current;
        el.style.width = trackW + 'px';

        // Wrap-around for smoother infinite feel
        if (offset > total / 2) offset -= total;
        if (offset < -total / 2) offset += total;

        const absOffset = Math.abs(offset);
        let tx, scale, opacity, z;

        if (offset === 0) {
          tx = 0;
          scale = 1;
          opacity = 1;
          z = 3;
          el.classList.add('is-center');
        } else {
          const dir = offset > 0 ? 1 : -1;
          tx = dir * 55 * (1 + absOffset * 0.3);
          scale = Math.max(0.75, 1 - absOffset * 0.12);
          opacity = Math.max(0.15, 1 - absOffset * 0.35);
          z = absOffset === 1 ? 2 : 1;
          el.classList.remove('is-center');
        }

        el.style.transform = `translateX(${tx}%) scale(${scale})`;
        el.style.opacity = opacity;
        el.style.zIndex = z;

        dot.classList.toggle('is-active', i === this.current);
      });
    }

    startAutoplay() {
      this.stopAutoplay();
      this.autoplay = setInterval(() => this.next(), 4000);
    }

    stopAutoplay() {
      if (this.autoplay) { clearInterval(this.autoplay); this.autoplay = null; }
    }

    pauseAutoplay() { this.stopAutoplay(); }

    resetAutoplay() {
      this.stopAutoplay();
      this.startAutoplay();
    }
  }

  new Carousel3D();
</script>
