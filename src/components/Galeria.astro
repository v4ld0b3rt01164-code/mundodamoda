---
// Galeria — Coverflow 3D com animação JS (sem depender de CSS transitions)
const slides = [
  { src: '/galeria/look-cowboy.jpg', alt: 'Look country — vestido brilhante com chapéu e botas' },
  { src: '/galeria/conjunto-azul-floral.jpg', alt: 'Conjunto blazer e saia — estampa floral azul' },
  { src: '/galeria/calca-infantil.jpg', alt: 'Calça moletom infantil — conforto e qualidade' },
  { src: '/1.jpg', alt: 'Modelo com look da Mundo da Moda' },
  { src: '/ig_2.jpg', alt: 'Look country com chapéu e botas' },
  { src: '/ig_3.jpg', alt: 'Conjunto estampado floral' },
  { src: '/ig_5.jpg', alt: 'Look casual feminino' },
  { src: '/ig_6.jpg', alt: 'Moda feminina estilo' },
  { src: '/ig_8.jpg', alt: 'Vestido estampado' },
  { src: '/ig_10.jpg', alt: 'Conjunto elegante' },
  { src: '/ig_11.jpg', alt: 'Look moderno' },
];
---

<section id="galeria" style="background:#16130F; padding:64px 0">
  <div style="max-width:980px; margin:0 auto; padding:0 32px">

    <div class="stage-clip">
      <div class="stage">
        <div class="coverflow" id="coverflow">
          {slides.map((s, i) => (
            <div class="card" data-i={i}>
              <img src={s.src} alt={s.alt} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="controls">
      <button id="cfPrev" aria-label="Anterior">&#8249;</button>
      <div class="dots" id="cfDots">
        {slides.map((_, i) => (
          <span class={i === 0 ? 'active' : ''}></span>
        ))}
      </div>
      <button id="cfNext" aria-label="Próximo">&#8250;</button>
    </div>
    <div class="name-caption" id="cfCaption"></div>

    <div style="text-align:center; margin-top:56px">
      <a href="https://www.instagram.com/mundo_da_moda_miguelopolis/" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:8px; padding:16px 32px; border:1px solid rgba(247,245,242,0.2); color:rgba(247,245,242,0.7); text-decoration:none; font-family:'Work Sans',system-ui,sans-serif; font-weight:600; font-size:14px; letter-spacing:1px; text-transform:uppercase; transition:all 0.3s">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        Mais looks no Instagram
      </a>
    </div>

  </div>
</section>

<style is:inline>
  .stage-clip { overflow: hidden; padding: 40px 0 60px; }
  .stage { position: relative; height: 380px; perspective: 1200px; -webkit-perspective: 1200px; display: flex; align-items: center; justify-content: center; }
  .coverflow { position: relative; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; transform-style: preserve-3d; -webkit-transform-style: preserve-3d; }
  .coverflow .card { position: absolute; width: 190px; height: 270px; border-radius: 8px; overflow: hidden; background: #17171a; border: 1px solid rgba(201,162,75,.3); box-shadow: 0 18px 34px rgba(0,0,0,.5); backface-visibility: hidden; -webkit-backface-visibility: hidden; cursor: pointer; }
  .coverflow .card img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .controls { display: flex; align-items: center; justify-content: center; gap: 18px; margin-top: 8px; font-family: 'Work Sans', 'Helvetica Neue', Arial, sans-serif; }
  .controls button { width: 42px; height: 42px; border-radius: 50%; border: 1px solid rgba(201,162,75,.5); background: transparent; color: #e6cd8a; font-size: 18px; cursor: pointer; transition: background .2s ease, transform .2s ease; }
  .controls button:hover { background: rgba(201,162,75,.15); }
  .controls button:active { transform: scale(.92); }
  .controls button:focus-visible { outline: 2px solid #e6cd8a; outline-offset: 2px; }
  .dots { display: flex; gap: 7px; }
  .dots span { width: 6px; height: 6px; border-radius: 50%; background: rgba(201,162,75,.3); transition: background .25s ease, transform .25s ease; }
  .dots span.active { background: #c9a24b; transform: scale(1.3); }
  .name-caption { text-align: center; font-family: 'Work Sans', 'Helvetica Neue', Arial, sans-serif; font-size: 13px; color: #9a9490; margin-top: 14px; min-height: 18px; }
  .name-caption b { color: #e6cd8a; font-weight: 500; }
  @media (max-width: 560px) { .stage { height: 320px; } .coverflow .card { width: 150px; height: 220px; } }
  @media (prefers-reduced-motion: reduce) { .coverflow .card { transition: none !important; } }
</style>

<script is:inline>
(function () {
  var cards = document.querySelectorAll('#coverflow .card');
  var dotsWrap = document.getElementById('cfDots');
  var caption = document.getElementById('cfCaption');
  var n = cards.length;
  var active = 0;

  var altTexts = [
    'Look country — vestido brilhante com chapéu e botas',
    'Conjunto blazer e saia — estampa floral azul',
    'Calça moletom infantil — conforto e qualidade',
    'Modelo com look da Mundo da Moda',
    'Look country com chapéu e botas',
    'Conjunto estampado floral',
    'Look casual feminino',
    'Moda feminina estilo',
    'Vestido estampado',
    'Conjunto elegante',
    'Look moderno'
  ];

  /* cubic-bezier(.22,.85,.32,1) */
  var segs = [
    { mx: 0.0625, my: 0.8381 },
    { mx: 0.3281, my: 0.9514 },
    { mx: 0.7344, my: 1.0 }
  ];
  function cubicEase(t) {
    var cx = 3 * segs[0].mx;
    var bx = 3 * (segs[1].mx - segs[0].mx) - cx;
    var ax = 1 - cx - bx;
    var cy = 3 * segs[0].my;
    var by = 3 * (segs[1].my - segs[0].my) - cy;
    var ay = 1 - cy - by;
    var x = t;
    for (var i = 0; i < 8; i++) {
      var evalX = ((ax * x + bx) * x + cx) * x - t;
      if (Math.abs(evalX) < 0.001) break;
      var dx = (3 * ax * x + 2 * bx) * x + cx;
      if (Math.abs(dx) < 1e-6) break;
      x -= evalX / dx;
    }
    return ((ay * x + by) * x + cy) * x;
  }

  var DURATION = 550;
  var anims = [];
  var activeAnim = 0;

  function targetFor(offset) {
    var abs = Math.abs(offset);
    var dir = Math.sign(offset);
    if (abs === 0) return { tx: 0, tz: 0, ry: 0, sc: 1, op: 1, z: 5 };
    return {
      tx: dir * Math.min(abs, 3) * 95,
      tz: -abs * 110,
      ry: -dir * 42,
      sc: Math.max(1 - abs * 0.14, 0.55),
      op: abs > 3 ? 0 : 1 - abs * 0.18,
      z: 5 - abs
    };
  }

  function applyCard(card, v) {
    var t = 'translateX(' + v.tx + 'px) translateZ(' + v.tz + 'px) rotateY(' + v.ry + 'deg) scale(' + v.sc + ')';
    card.style.transform = t;
    card.style.webkitTransform = t;
    card.style.zIndex = v.z;
    card.style.opacity = v.op;
    card.style.pointerEvents = v.op <= 0 ? 'none' : 'auto';
  }

  function animateTo(targets) {
    var id = ++activeAnim;
    var start = null;
    var from = [];
    var to = [];

    for (var i = 0; i < n; i++) {
      var ct = cards[i].style.transform || '';
      var mTx = ct.match(/translateX\(([-.\d]+)px\)/);
      var mTz = ct.match(/translateZ\(([-.\d]+)px\)/);
      var mRy = ct.match(/rotateY\(([-.\d]+)deg\)/);
      var mSc = ct.match(/scale\(([-.\d]+)\)/);
      from.push({
        tx: mTx ? parseFloat(mTx[1]) : 0,
        tz: mTz ? parseFloat(mTz[1]) : 0,
        ry: mRy ? parseFloat(mRy[1]) : 0,
        sc: mSc ? parseFloat(mSc[1]) : 1,
        op: parseFloat(cards[i].style.opacity) || 0,
        z: parseInt(cards[i].style.zIndex) || 0
      });
      to.push(targets[i]);
    }

    function step(ts) {
      if (id !== activeAnim) return;
      if (!start) start = ts;
      var raw = (ts - start) / DURATION;
      var p = Math.min(raw, 1);
      var e = cubicEase(p);

      for (var i = 0; i < n; i++) {
        var f = from[i];
        var t = to[i];
        applyCard(cards[i], {
          tx: f.tx + (t.tx - f.tx) * e,
          tz: f.tz + (t.tz - f.tz) * e,
          ry: f.ry + (t.ry - f.ry) * e,
          sc: f.sc + (t.sc - f.sc) * e,
          op: f.op + (t.op - f.op) * e,
          z: t.z
        });
      }

      if (raw < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function render() {
    var targets = [];
    for (var i = 0; i < n; i++) {
      var offset = i - active;
      if (offset > n / 2) offset -= n;
      if (offset < -n / 2) offset += n;
      targets.push(targetFor(offset));
    }
    animateTo(targets);

    var dots = dotsWrap.children;
    for (var d = 0; d < dots.length; d++) {
      dots[d].classList.toggle('active', d === active);
    }
    caption.innerHTML = '<b>' + altTexts[active] + '</b>';
  }

  function goNext() { active = (active + 1) % n; render(); }
  function goPrev() { active = (active - 1 + n) % n; render(); }

  function createAutoplay(hEl, adv, delay) {
    var timer = null;
    function start() { stop(); timer = setInterval(adv, delay); }
    function stop() { if (timer) clearInterval(timer); timer = null; }
    hEl.addEventListener('mouseenter', stop);
    hEl.addEventListener('mouseleave', start);
    hEl.addEventListener('touchstart', stop, { passive: true });
    hEl.addEventListener('touchend', start, { passive: true });
    start();
    return { reset: function () { start(); }, stop: stop };
  }

  for (var i = 0; i < n; i++) {
    (function (idx) {
      cards[idx].addEventListener('click', function () {
        if (idx === active) return;
        active = idx;
        render();
        if (auto) auto.reset();
      });
    })(i);
  }

  var auto = createAutoplay(document.querySelector('#coverflow').closest('.stage'), goNext, 1500);
  document.getElementById('cfNext').addEventListener('click', function () { goNext(); auto.reset(); });
  document.getElementById('cfPrev').addEventListener('click', function () { goPrev(); auto.reset(); });
  render();
})();
</script>
