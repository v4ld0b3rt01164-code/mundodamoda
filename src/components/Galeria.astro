<style>
  /* Safari: overflow:hidden NUNCA no mesmo elemento que preserve-3d */
  .cf-stage-clip {
    overflow: hidden;
    padding: 40px 0 60px;
  }

  .cf-stage {
    position: relative;
    height: 460px;
    perspective: 1200px;
    -webkit-perspective: 1200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cf-coverflow {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    -webkit-transform-style: preserve-3d;
  }

  .cf-card {
    position: absolute;
    width: 210px;
    height: 300px;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid rgba(201, 162, 75, 0.3);
    box-shadow: 0 18px 34px rgba(0, 0, 0, 0.5);
    transition: transform 0.55s cubic-bezier(0.22, 0.85, 0.32, 1), opacity 0.55s ease;
    -webkit-transition: -webkit-transform 0.55s cubic-bezier(0.22, 0.85, 0.32, 1), opacity 0.55s ease;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .cf-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cf-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    -webkit-transform: translateY(-50%);
    z-index: 20;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(247, 245, 242, 0.2);
    background: rgba(22, 19, 15, 0.8);
    color: rgba(247, 245, 242, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .cf-arrow:hover {
    background: rgba(201, 162, 75, 0.2);
    border-color: rgba(201, 162, 75, 0.5);
    color: #C9A24B;
  }

  .cf-arrow:active {
    transform: translateY(-50%) scale(0.92);
    -webkit-transform: translateY(-50%) scale(0.92);
  }

  .cf-arrow--prev { left: 10px; }
  .cf-arrow--next { right: 10px; }

  .cf-dots {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    -webkit-transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 20;
  }

  .cf-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(201, 162, 75, 0.3);
    transition: background 0.25s ease, transform 0.25s ease;
    padding: 0;
    border: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .cf-dot.is-active {
    background: #C9A24B;
    transform: scale(1.35);
  }

  @media (min-width: 640px) {
    .cf-stage { height: 540px; }
    .cf-card { width: 250px; height: 350px; }
    .cf-arrow { width: 48px; height: 48px; }
    .cf-arrow--prev { left: 20px; }
    .cf-arrow--next { right: 20px; }
  }

  @media (min-width: 1024px) {
    .cf-stage { height: 580px; }
    .cf-card { width: 280px; height: 390px; }
    .cf-arrow--prev { left: calc(50% - 230px); }
    .cf-arrow--next { right: calc(50% - 230px); }
  }

  @media (max-width: 480px) {
    .cf-stage { height: 400px; }
    .cf-card { width: 180px; height: 260px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cf-card {
      transition: none !important;
      -webkit-transition: none !important;
    }
  }
</style>

<script>
  const SLIDES = [
    { src: '/galeria/look-cowboy.jpg', alt: 'Look country — vestido brilhante com chapéu e botas' },
    { src: '/galeria/conjunto-azul-floral.jpg', alt: 'Conjunto blazer e saia — estampa floral azul' },
    { src: '/galeria/calca-infantil.jpg', alt: 'Calça moletom infantil — conforto e qualidade' },
    { src: '/1.jpg', alt: 'Modelo com look da Mundo da Moda' },
    { src: '/ig_2.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_3.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_5.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_6.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_8.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_10.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_11.jpg', alt: 'Look da loja Mundo da Moda' },
  ];

  (function () {
    const wrap = document.getElementById('coverflowWrap');
    const dotsWrap = document.getElementById('cfDots');
    const n = SLIDES.length;
    let active = 0;
    let timer = null;
    const cards = [];

    SLIDES.forEach((p, i) => {
      const card = document.createElement('div');
      card.className = 'cf-card';
      card.innerHTML = `<img src="${p.src}" alt="${p.alt}" loading="${i < 2 ? 'eager' : 'lazy'}">`;
      card.addEventListener('click', () => {
        if (i === active) return;
        active = i;
        render();
        resetAutoplay();
      });
      wrap.appendChild(card);
      cards.push(card);

      const dot = document.createElement('button');
      dot.className = 'cf-dot';
      if (i === 0) dot.classList.add('is-active');
      dot.setAttribute('aria-label', `Slide ${i + 1}`);
      dot.addEventListener('click', () => { active = i; render(); resetAutoplay(); });
      dotsWrap.appendChild(dot);
    });

    function styleFor(offset) {
      const abs = Math.abs(offset);
      const dir = Math.sign(offset) || 0;
      if (abs === 0) {
        return { t: 'translateX(0) translateZ(0) rotateY(0deg) scale(1)', z: 5, op: 1 };
      }
      const x = dir * Math.min(abs, 3) * 95;
      const z = -abs * 110;
      const rot = -dir * 42;
      const scale = Math.max(1 - abs * 0.14, 0.55);
      const op = abs > 3 ? 0 : 1 - abs * 0.18;
      return { t: `translateX(${x}px) translateZ(${z}px) rotateY(${rot}deg) scale(${scale})`, z: 5 - abs, op };
    }

    function render() {
      cards.forEach((card, i) => {
        let offset = i - active;
        if (offset > n / 2) offset -= n;
        if (offset < -n / 2) offset += n;
        const s = styleFor(offset);
        card.style.transform = s.t;
        card.style.webkitTransform = s.t;
        card.style.zIndex = s.z;
        card.style.opacity = s.op;
        card.style.pointerEvents = s.op <= 0 ? 'none' : 'auto';
      });
      [...dotsWrap.children].forEach((d, i) => d.classList.toggle('is-active', i === active));
    }

    function goNext() { active = (active + 1) % n; render(); }
    function goPrev() { active = (active - 1 + n) % n; render(); }

    function startAutoplay() {
      stopAutoplay();
      timer = setInterval(goNext, 3500);
    }

    function stopAutoplay() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    function resetAutoplay() { stopAutoplay(); startAutoplay(); }

    document.getElementById('cfNext').addEventListener('click', () => { goNext(); resetAutoplay(); });
    document.getElementById('cfPrev').addEventListener('click', () => { goPrev(); resetAutoplay(); });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { goPrev(); resetAutoplay(); }
      if (e.key === 'ArrowRight') { goNext(); resetAutoplay(); }
    });

    const stage = wrap.closest('.cf-stage');
    stage.addEventListener('mouseenter', stopAutoplay);
    stage.addEventListener('mouseleave', startAutoplay);
    stage.addEventListener('touchstart', stopAutoplay, { passive: true });
    stage.addEventListener('touchend', () => resetAutoplay());

    render();
    startAutoplay();
  })();
</script>
