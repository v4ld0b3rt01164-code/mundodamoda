<style is:global>
  .stage-clip {
    overflow: hidden;
    padding: 40px 0 60px;
  }

  .stage {
    position: relative;
    height: 380px;
    perspective: 1200px;
    -webkit-perspective: 1200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .coverflow {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    -webkit-transform-style: preserve-3d;
  }

  .coverflow .card {
    position: absolute;
    width: 190px;
    height: 270px;
    border-radius: 8px;
    overflow: hidden;
    background: #17171a;
    border: 1px solid rgba(201, 162, 75, 0.3);
    box-shadow: 0 18px 34px rgba(0, 0, 0, 0.5);
    transition: transform .55s cubic-bezier(.22, .85, .32, 1), opacity .55s ease, filter .55s ease;
    -webkit-transition: -webkit-transform .55s cubic-bezier(.22, .85, .32, 1), opacity .55s ease, -webkit-filter .55s ease;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    cursor: pointer;
  }

  .coverflow .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-top: 8px;
  }

  .controls button {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(201, 162, 75, 0.5);
    background: transparent;
    color: #e6cd8a;
    font-size: 18px;
    cursor: pointer;
    transition: background .2s ease, transform .2s ease;
  }

  .controls button:hover {
    background: rgba(201, 162, 75, .15);
  }

  .controls button:active {
    transform: scale(.92);
  }

  .controls button:focus-visible {
    outline: 2px solid #e6cd8a;
    outline-offset: 2px;
  }

  .dots {
    display: flex;
    gap: 7px;
  }

  .dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(201, 162, 75, .3);
    transition: background .25s ease, transform .25s ease;
  }

  .dots span.active {
    background: #c9a24b;
    transform: scale(1.3);
  }

  @media (max-width: 560px) {
    .stage {
      height: 320px;
    }

    .coverflow .card {
      width: 150px;
      height: 220px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .coverflow .card {
      transition: none !important;
      -webkit-transition: none !important;
    }
  }
</style>

<script>
  const SLIDES = [
    { src: '/galeria/look-cowboy.jpg', alt: 'Look country — vestido brilhante com chapéu e botas' },
    { src: '/galeria/conjunto-azul-floral.jpg', alt: 'Conjunto blazer e saia — estampa floral azul' },
    { src: '/galeria/calca-infantil.jpg', alt: 'Calça moletom infantil — conforto e qualidade' },
    { src: '/1.jpg', alt: 'Modelo com look da Mundo da Moda' },
    { src: '/ig_2.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_3.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_5.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_6.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_8.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_10.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_11.jpg', alt: 'Look da loja Mundo da Moda' },
  ];

  /* =========================================================
     AUTOPLAY HELPER
  ========================================================= */
  function createAutoplay(hoverEl, advance, delay) {
    let timer = null;
    function start() {
      stop();
      timer = setInterval(advance, delay);
    }
    function stop() {
      if (timer) clearInterval(timer);
      timer = null;
    }
    hoverEl.addEventListener('mouseenter', stop);
    hoverEl.addEventListener('mouseleave', start);
    hoverEl.addEventListener('touchstart', stop, { passive: true });
    hoverEl.addEventListener('touchend', start, { passive: true });

    start();
    return {
      reset() { start(); },
      stop
    };
  }

  /* =========================================================
     DEMO 2 — COVERFLOW
  ========================================================= */
  (function () {
    const wrap = document.getElementById('coverflow');
    const dotsWrap = document.getElementById('cfDots');
    const n = SLIDES.length;
    let active = 0;
    const cards = [];

    SLIDES.forEach((p, i) => {
      const card = document.createElement('div');
      card.className = 'card';
      card.innerHTML = `<img src="${p.src}" alt="${p.alt}" loading="lazy">`;
      card.addEventListener('click', () => {
        if (i === active) return;
        active = i;
        render();
        if (auto) auto.reset();
      });
      wrap.appendChild(card);
      cards.push(card);

      const dot = document.createElement('span');
      if (i === 0) dot.classList.add('active');
      dotsWrap.appendChild(dot);
    });

    function styleFor(offset) {
      const abs = Math.abs(offset);
      const dir = Math.sign(offset);
      if (abs === 0) {
        return { t: 'translateX(0) translateZ(0) rotateY(0deg) scale(1)', z: 5, op: 1 };
      }
      const x = dir * Math.min(abs, 3) * 95;
      const z = -abs * 110;
      const rot = -dir * 42;
      const scale = Math.max(1 - abs * 0.14, 0.55);
      const op = abs > 3 ? 0 : 1 - abs * 0.18;
      return { t: `translateX(${x}px) translateZ(${z}px) rotateY(${rot}deg) scale(${scale})`, z: 5 - abs, op };
    }

    function render() {
      cards.forEach((card, i) => {
        let offset = i - active;
        // wrap-around to shortest path
        if (offset > n / 2) offset -= n;
        if (offset < -n / 2) offset += n;
        const s = styleFor(offset);
        card.style.transform = s.t;
        card.style.webkitTransform = s.t;
        card.style.zIndex = s.z;
        card.style.opacity = s.op;
        card.style.pointerEvents = s.op <= 0 ? 'none' : 'auto';
      });
      [...dotsWrap.children].forEach((d, i) => d.classList.toggle('active', i === active));
    }
    function goNext() { active = (active + 1) % n; render(); }
    function goPrev() { active = (active - 1 + n) % n; render(); }

    const auto = createAutoplay(wrap.closest('.stage'), goNext, 3200);
    document.getElementById('cfNext').addEventListener('click', () => { goNext(); auto.reset(); });
    document.getElementById('cfPrev').addEventListener('click', () => { goPrev(); auto.reset(); });
    render();
  })();
</script>
