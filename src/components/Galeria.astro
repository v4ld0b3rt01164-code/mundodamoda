---
// Galeria — Coverflow 3D (Demo 2 do carrossel-3d.html)
---

<section id="galeria" style="background:#16130F; padding:64px 0">
  <div style="max-width:980px; margin:0 auto; padding:0 32px">

    <div class="stage-clip">
      <div class="stage">
        <div class="coverflow" id="coverflow"></div>
      </div>
    </div>
    <div class="controls">
      <button id="cfPrev" aria-label="Anterior">&#8249;</button>
      <div class="dots" id="cfDots"></div>
      <button id="cfNext" aria-label="Próximo">&#8250;</button>
    </div>
    <div class="name-caption" id="cfCaption"></div>

    <div style="text-align:center; margin-top:56px">
      <a href="https://www.instagram.com/mundo_da_moda_miguelopolis/" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:8px; padding:16px 32px; border:1px solid rgba(247,245,242,0.2); color:rgba(247,245,242,0.7); text-decoration:none; font-family:'Work Sans',system-ui,sans-serif; font-weight:600; font-size:14px; letter-spacing:1px; text-transform:uppercase; transition:all 0.3s">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        Mais looks no Instagram
      </a>
    </div>

  </div>
</section>

<style is:inline>
  .stage-clip {
    overflow: hidden;
    padding: 40px 0 60px;
  }
  .stage {
    position: relative;
    height: 380px;
    perspective: 1200px;
    -webkit-perspective: 1200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .coverflow {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    -webkit-transform-style: preserve-3d;
  }
  .coverflow .card {
    position: absolute;
    width: 190px;
    height: 270px;
    border-radius: 8px;
    overflow: hidden;
    background: #17171a;
    border: 1px solid rgba(201, 162, 75, 0.3);
    box-shadow: 0 18px 34px rgba(0, 0, 0, 0.5);
    transition: transform .55s cubic-bezier(.22, .85, .32, 1), opacity .55s ease, filter .55s ease;
    -webkit-transition: -webkit-transform .55s cubic-bezier(.22, .85, .32, 1), opacity .55s ease, -webkit-filter .55s ease;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    cursor: pointer;
  }
  .coverflow .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-top: 8px;
    font-family: 'Helvetica Neue', Arial, sans-serif;
  }
  .controls button {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(201, 162, 75, 0.5);
    background: transparent;
    color: #e6cd8a;
    font-size: 18px;
    cursor: pointer;
    transition: background .2s ease, transform .2s ease;
  }
  .controls button:hover {
    background: rgba(201, 162, 75, .15);
  }
  .controls button:active {
    transform: scale(.92);
  }
  .controls button:focus-visible {
    outline: 2px solid #e6cd8a;
    outline-offset: 2px;
  }
  .dots {
    display: flex;
    gap: 7px;
  }
  .dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(201, 162, 75, .3);
    transition: background .25s ease, transform .25s ease;
  }
  .dots span.active {
    background: #c9a24b;
    transform: scale(1.3);
  }
  .name-caption {
    text-align: center;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 13px;
    color: #9a9490;
    margin-top: 14px;
    min-height: 18px;
  }
  .name-caption b {
    color: #e6cd8a;
    font-weight: 500;
  }
  @media (max-width: 560px) {
    .stage { height: 320px; }
    .coverflow .card { width: 150px; height: 220px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .coverflow .card { transition: none !important; -webkit-transition: none !important; }
  }
</style>

<script>
  var SLIDES = [
    { src: '/galeria/look-cowboy.jpg', alt: 'Look country — vestido brilhante com chapéu e botas' },
    { src: '/galeria/conjunto-azul-floral.jpg', alt: 'Conjunto blazer e saia — estampa floral azul' },
    { src: '/galeria/calca-infantil.jpg', alt: 'Calça moletom infantil — conforto e qualidade' },
    { src: '/1.jpg', alt: 'Modelo com look da Mundo da Moda' },
    { src: '/ig_2.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_3.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_5.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_6.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_8.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_10.jpg', alt: 'Look da loja Mundo da Moda' },
    { src: '/ig_11.jpg', alt: 'Look da loja Mundo da Moda' }
  ];

  /* =========================================================
     AUTOPLAY HELPER
  ========================================================= */
  function createAutoplay(hoverEl, advance, delay) {
    var timer = null;
    function start() {
      stop();
      timer = setInterval(advance, delay);
    }
    function stop() {
      if (timer) clearInterval(timer);
      timer = null;
    }
    hoverEl.addEventListener('mouseenter', stop);
    hoverEl.addEventListener('mouseleave', start);
    hoverEl.addEventListener('touchstart', stop, { passive: true });
    hoverEl.addEventListener('touchend', start, { passive: true });

    start();
    return {
      reset: function () { start(); },
      stop: stop
    };
  }

  /* =========================================================
     COVERFLOW (Demo 2 — carrossel-3d.html)
  ========================================================= */
  (function () {
    var wrap = document.getElementById('coverflow');
    var dotsWrap = document.getElementById('cfDots');
    var caption = document.getElementById('cfCaption');
    var n = SLIDES.length;
    var active = 0;
    var cards = [];

    SLIDES.forEach(function (p, i) {
      var card = document.createElement('div');
      card.className = 'card';
      card.innerHTML = '<img src="' + p.src + '" alt="' + p.alt + '" loading="lazy">';
      card.addEventListener('click', function () {
        if (i === active) return;
        active = i;
        render();
        if (auto) auto.reset();
      });
      wrap.appendChild(card);
      cards.push(card);

      var dot = document.createElement('span');
      if (i === 0) dot.classList.add('active');
      dotsWrap.appendChild(dot);
    });

    function styleFor(offset) {
      var abs = Math.abs(offset);
      var dir = Math.sign(offset);
      if (abs === 0) {
        return { t: 'translateX(0) translateZ(0) rotateY(0deg) scale(1)', z: 5, op: 1 };
      }
      var x = dir * Math.min(abs, 3) * 95;
      var z = -abs * 110;
      var rot = -dir * 42;
      var scale = Math.max(1 - abs * 0.14, 0.55);
      var op = abs > 3 ? 0 : 1 - abs * 0.18;
      return { t: 'translateX(' + x + 'px) translateZ(' + z + 'px) rotateY(' + rot + 'deg) scale(' + scale + ')', z: 5 - abs, op: op };
    }

    function render() {
      cards.forEach(function (card, i) {
        var offset = i - active;
        if (offset > n / 2) offset -= n;
        if (offset < -n / 2) offset += n;
        var s = styleFor(offset);
        card.style.transform = s.t;
        card.style.webkitTransform = s.t;
        card.style.zIndex = s.z;
        card.style.opacity = s.op;
        card.style.pointerEvents = s.op <= 0 ? 'none' : 'auto';
      });
      var dots = dotsWrap.children;
      for (var d = 0; d < dots.length; d++) {
        if (d === active) { dots[d].classList.add('active'); }
        else { dots[d].classList.remove('active'); }
      }
      caption.innerHTML = '<b>' + SLIDES[active].alt + '</b>';
    }
    function goNext() { active = (active + 1) % n; render(); }
    function goPrev() { active = (active - 1 + n) % n; render(); }

    var auto = createAutoplay(wrap.closest('.stage'), goNext, 1500);
    document.getElementById('cfNext').addEventListener('click', function () { goNext(); auto.reset(); });
    document.getElementById('cfPrev').addEventListener('click', function () { goPrev(); auto.reset(); });
    render();
  })();
</script>
